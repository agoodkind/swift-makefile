#!/usr/bin/env bash
set -eu

# swift-mk's ad-hoc signing carve-out is human-only. Refuse a commit that changes
# AdHocSigningAllowlist.swift so the allowlist cannot be widened in an automated
# flow. agent-gate already blocks an agent from editing or shell-mutating the file;
# this is the commit-time backstop. A human making a deliberate change commits with
# `git commit --no-verify`, which agent-gate forbids agents from using.
if git diff --cached --name-only --diff-filter=ACM \
    | grep -qE '(^|/)AdHocSigningAllowlist\.swift$'; then
    printf '%s\n' \
        "pre-commit: refusing to commit a change to swift-mk's ad-hoc signing carve-out (AdHocSigningAllowlist.swift)." \
        "Widening the allowlist must be a deliberate human edit. If that is what this is, commit with: git commit --no-verify" >&2
    exit 1
fi

staged=$(git diff --cached --name-only --diff-filter=ACM -- '*.swift' || true)
[[ -z "${staged}" ]] && exit 0

git_root=$(git rev-parse --show-toplevel)

find_makefile_dir() {
    local file_path="$1"
    local directory_path

    directory_path=$(dirname "${git_root}/${file_path}")
    while [[ "${directory_path}" != "/" && "${directory_path}" != "${git_root}/.." ]]; do
        if [[ -f "${directory_path}/Makefile" ]] && grep -qE '^(include|-include) bootstrap\.mk$' "${directory_path}/Makefile"; then
            printf '%s\n' "${directory_path}"
            return 0
        fi
        directory_path=$(dirname "${directory_path}")
    done
    return 1
}

declare -A by_dir
while IFS= read -r file_path; do
    [[ -n "${file_path}" ]] || continue
    if mk_dir=$(find_makefile_dir "${file_path}"); then
        mk_dir_rel="${mk_dir#${git_root}/}"
        if [[ "${mk_dir_rel}" == "${mk_dir}" ]]; then
            rel_path="${file_path}"
        else
            rel_path="${file_path#${mk_dir_rel}/}"
        fi
        by_dir["${mk_dir}"]+="${rel_path} "
    fi
done <<< "${staged}"

status=0
for mk_dir in "${!by_dir[@]}"; do
    (
        cd "${mk_dir}"
        make lint-diff
    ) || status=$?
done

exit "${status}"
